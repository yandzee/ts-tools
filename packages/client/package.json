{
  "name": "@yandzee/client",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch --noEmit",
    "build:dev": "tsdown -c tsdown.dev.ts",
    "build": "tsdown -c tsdown.build.ts",
    "check:types": "tsc --noEmit",
    "check:lint": "biome check",
    "check:test": "vitest"
  },
  "exports": {
    "./data/page": "./dist/data/page.js",
    "./data/pages": "./dist/data/pages.js",
    "./disposer": "./dist/disposer.js",
    "./dom": "./dist/dom.js",
    "./events": "./dist/events.js",
    "./http": "./dist/http/index.js",
    "./http/api": "./dist/http/api.js",
    "./http/client": "./dist/http/client.js",
    "./http/result": "./dist/http/result.js",
    "./loader": "./dist/loader.js",
    "./notifications": "./dist/notifications.js",
    "./timer": "./dist/timer.js",
    "./types": "./dist/types.js",
    "./utils": "./dist/utils/index.js",
    "./zod/date": "./dist/zod/date.js",
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:^",
    "@repo/tsdown": "workspace:^",
    "@types/node": "^24.10.2",
    "tsdown": "^0.16.4",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@7.2.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "es-toolkit": "^1.41.0",
    "zod": "^4.1.13"
  }
}
